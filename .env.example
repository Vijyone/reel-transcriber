# Copy this file to .env and fill in your real values.

# --- Notion ---
# 1. Go to https://www.notion.so/profile/integrations
# 2. Create a new internal integration, copy the secret token (starts with "ntn_" or "secret_").
# 3. Open your reel database in Notion -> ... menu -> Connections -> add the integration.
# 4. Database ID is the 32-char hex string in the database URL after your workspace name and before the "?".
NOTION_TOKEN=ntn_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_DATABASE_ID=00000000000000000000000000000000

# --- Groq (Whisper transcription) ---
# 1. Sign up at https://console.groq.com (free tier is generous).
# 2. API Keys -> Create API Key.
# 3. Whisper-large-v3 costs ~$0.04/hour of audio; whisper-large-v3-turbo is even cheaper.
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
