# Copy this file to .env and fill in your real values.

# --- Notion ---
# 1. Go to https://www.notion.so/profile/integrations
# 2. Create a new internal integration, copy the secret token (starts with "ntn_" or "secret_").
# 3. Open your database in Notion -> ... menu -> Connections -> add the integration.
# 4. Database ID is the 32-char hex in the database URL after your workspace name and before the "?".
#    (Or just paste the full URL into the app — it'll extract it for you.)
NOTION_TOKEN=ntn_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_DATABASE_ID=00000000000000000000000000000000
